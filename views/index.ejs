<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <h1><%= title %></h1>
    <% if (user) { %>
      <p>Welcome, <strong><%= user.username %></strong>!</p>
      <p><a href="/users/logout">Logout</a></p>
    <% } else { %>
      <p><a href="/users/login">Login</a> or <a href="/users/register">Register</a></p>
    <% } %>
  </body>
</html>
